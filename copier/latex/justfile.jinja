# Show available recipes.
default:
  @just --list

# Bootstrap the project (git init, hooks).
init:
  if [ ! -d .git ]; then git init; fi
  pre-commit install --install-hooks

# Format a TeX source.
fmt file='main.tex':
  latexindent -w -s "{% raw %}{{file}}{% endraw %}"

# Build the PDF.
build file='main.tex':
  env -u SOURCE_DATE_EPOCH latexmk "{% raw %}{{file}}{% endraw %}"

# Rebuild the PDF when sources change.
watch file='main.tex':
  env -u SOURCE_DATE_EPOCH latexmk -pvc "{% raw %}{{file}}{% endraw %}"

# Lint a TeX source.
check file='main.tex':
  chktex -q -n 1 "{% raw %}{{file}}{% endraw %}"

# CI alias.
ci file='main.tex':
  just check "{% raw %}{{file}}{% endraw %}"
  just build "{% raw %}{{file}}{% endraw %}"

# Create a GitHub repository and set origin.
repo-create name='{{ project_name }}' visibility='{{ github_visibility }}': init
  case "{% raw %}{{visibility}}{% endraw %}" in public|private|internal) ;; *) echo "visibility must be one of: public, private, internal"; exit 2 ;; esac
  if ! gh auth status >/dev/null 2>&1; then echo "GitHub CLI is not authenticated. Run: gh auth login"; exit 2; fi
  gh repo create "{% raw %}{{name}}{% endraw %}" --source=. --remote=origin --"{% raw %}{{visibility}}{% endraw %}"

# Remove generated files.
clean file='main.tex':
  latexmk -C "{% raw %}{{file}}{% endraw %}"
  rm -rf build
